    {
      "parameters": {
        "jsCode": "try {\n    const data = $input.first().json;\n    const rawText = data.text || \"\";\n    \n    if (!rawText) {\n        throw new Error(\"Field 'text' is missing. Available keys: \" + Object.keys(data).join(\", \"));\n    }\n\n    const start = rawText.indexOf('{');\n    const end = rawText.lastIndexOf('}');\n    \n    if (start === -1 || end === -1) {\n        throw new Error(\"JSON not found in response. Text starts with: \" + rawText.substring(0, 100));\n    }\n\n    const jsonString = rawText.substring(start, end + 1);\n    const parsed = JSON.parse(jsonString);\n\n    return [{\n        json: {\n            \"Title\": parsed.blog?.page_title_h1 || \"missing\",\n            \"Meta Description\": parsed.blog?.meta_description || \"missing\",\n            \"URL\": parsed.blog?.page_url || \"missing\",\n            \"Draft\": parsed.blog?.draft || \"missing\",\n            \"Newsletter Creative Director\": parsed.newsletters?.creative_director?.body || \"missing\",\n            \"Newsletter Freelancer\": parsed.newsletters?.solo_freelancer?.body || \"missing\",\n            \"Newsletter Agency Manager\": parsed.newsletters?.agency_manager?.body || \"missing\",\n            \"Timestamp\": new Date().toISOString()\n        }\n    }];\n\n} catch(e) {\n    return [{\n        json: {\n            \"Title\": \"ERROR: \" + e.message.substring(0, 200),\n            \"Meta Description\": \"\", \n            \"URL\": \"\", \n            \"Draft\": \"\",\n            \"Newsletter Creative Director\": \"\",\n            \"Newsletter Freelancer\": \"\",\n            \"Newsletter Agency Manager\": \"\",\n            \"Timestamp\": new Date().toISOString()\n        }\n    }];\n}"
      },
