    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a content strategist for NovaMind, an AI automation startup targeting creative agencies.\n\nBased on this campaign's performance data and the blog topic that was just published, suggest 3 next blog topics that would likely perform better.\n\nCurrent topic: {{ $('Edit Fields').first().json.topic }}\nPerformance data: {{ JSON.stringify($json) }}\n\nReturn ONLY a JSON object like this:\n{\n  \"suggestions\": [\n    {\"title\": \"...\", \"reason\": \"...\"},\n    {\"title\": \"...\", \"reason\": \"...\"},\n    {\"title\": \"...\", \"reason\": \"...\"}\n  ]\n}\nNo markdown. No explanation.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
