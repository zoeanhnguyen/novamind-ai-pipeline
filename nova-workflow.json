      "parameters": {
        "respondWith": "text",
        "responseBody": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>NovaMind | Execution Dashboard</title>\n  <style>\n    :root { --bg: #0b0f1a; --card: #161b2c; --accent: #818cf8; --text: #f8fafc; --sub: #94a3b8; --success: #10b981; }\n    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); max-width: 800px; margin: 50px auto; padding: 20px; line-height: 1.5; }\n    header { border-bottom: 1px solid #2d3348; padding-bottom: 20px; margin-bottom: 30px; }\n    h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; margin: 0; color: var(--accent); }\n    .status-pill { display: inline-flex; align-items: center; background: rgba(16, 185, 129, 0.1); color: var(--success); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-top: 10px; }\n    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n    .card { background: var(--card); border-radius: 20px; padding: 24px; border: 1px solid #2d3348; }\n    .full { grid-column: span 2; }\n    h3 { font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: var(--sub); margin-bottom: 16px; margin-top: 0; }\n    .blog-title { font-size: 20px; font-weight: 700; margin-bottom: 12px; display: block; }\n    .btn-disabled { display: inline-block; background: #242b3d; color: var(--sub); padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-top: 15px; border: 1px solid #334155; cursor: default; }\n    .tag-container { display: flex; flex-wrap: wrap; gap: 8px; }\n    .tag { background: #242b3d; padding: 6px 14px; border-radius: 8px; font-size: 13px; border: 1px solid #334155; }\n    .insight-box { background: #0f172a; padding: 20px; border-radius: 12px; border-left: 4px solid var(--accent); color: #cbd5e1; font-size: 15px; }\n    .topic-item { background: #0f172a; border-radius: 10px; padding: 16px; margin-bottom: 10px; border: 1px solid #2d3348; }\n    .topic-title { font-weight: 600; font-size: 15px; color: var(--text); margin-bottom: 4px; }\n    .topic-reason { font-size: 13px; color: var(--sub); }\n    .topic-num { display: inline-block; background: var(--accent); color: white; width: 22px; height: 22px; border-radius: 50%; text-align: center; line-height: 22px; font-size: 12px; font-weight: 700; margin-right: 8px; }\n    .footer-meta { display: flex; justify-content: space-between; font-size: 12px; color: var(--sub); margin-top: 30px; padding-top: 20px; border-top: 1px solid #2d3348; }\n    .id-code { font-family: monospace; color: var(--accent); }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>NovaMind Pipeline</h1>\n    <div class=\"status-pill\">● System Active</div>\n  </header>\n\n  <div class=\"grid\">\n    <div class=\"card full\">\n      <h3>Primary Content</h3>\n      <span class=\"blog-title\">{{ $('Code in JavaScript').first().json.Title }}</span>\n      <p style=\"color: var(--sub); font-size: 15px;\">{{ $('Code in JavaScript').first().json['Meta Description'] }}</p>\n      <span class=\"btn-disabled\">Preview Only — Not Published</span>\n    </div>\n\n    <div class=\"card\">\n      <h3>Distribution</h3>\n      <div class=\"tag-container\">\n        <div class=\"tag\">Creative Director</div>\n        <div class=\"tag\">Solo Freelancer</div>\n        <div class=\"tag\">Agency Manager</div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <h3>Automation Status</h3>\n      <div style=\"font-size: 24px; font-weight: 700; color: var(--success);\">100%</div>\n      <p style=\"font-size: 12px; color: var(--sub); margin: 0;\">Data synced to Sheets</p>\n    </div>\n\n    <div class=\"card full\">\n      <h3>AI Performance Insight</h3>\n      <div class=\"insight-box\">{{ $('Performance Summary').first().json.text }}</div>\n    </div>\n\n    <div class=\"card full\">\n      <h3>Suggested Next Topics</h3>\n      {{ $('Suggestions').first().json.suggestions.map((s, i) => `\n        <div class=\"topic-item\">\n          <div class=\"topic-title\"><span class=\"topic-num\">${i+1}</span>${s.title}</div>\n          <div class=\"topic-reason\">${s.reason}</div>\n        </div>\n      `).join('') }}\n    </div>\n  </div>\n\n  <div class=\"footer-meta\">\n    <span>Execution ID: <span class=\"id-code\">{{ $('Edit Fields').first().json.campaign_id }}</span></span>\n    <span>{{ $('Edit Fields').first().json.timestamp }}</span>\n  </div>\n</body>\n</html>",
        "options": {
          "responseHeaders": {
