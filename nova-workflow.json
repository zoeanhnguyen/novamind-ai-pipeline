        "jsCode": "const campaignId = $('Edit Fields').first().json.campaign_id;\n// Sửa danh sách ở đây để ghi vào Sheet cho đẹp\nconst personas = ['Creative Director', 'Freelancer', 'Agency Manager'];\n\nreturn personas.map(persona => ({\n    json: {\n        \"Campaign ID\": campaignId,\n        \"Persona\": persona,\n        \"Open Rate\": parseFloat((Math.random() * 30 + 20).toFixed(1)),\n        \"Click Rate\": parseFloat((Math.random() * 10 + 2).toFixed(1)),\n        \"Unsubscribe Rate\": parseFloat((Math.random() * 1).toFixed(2)),\n        \"Emails Sent\": Math.floor(Math.random() * 50 + 10),\n        \"Timestamp\": new Date().toISOString()\n    }\n}));"
